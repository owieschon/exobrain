.DS_Store
*.tmp
# secrets / local env — defensive: this project stores no secrets, but never
# commit one by accident
.env
.env.*
*.pem
*.key
*.pfx
.secrets
credentials.json
# Python bytecode
__pycache__/
*.pyc
# stray lock
.lock
# runtime / generated state (not knowledge)
distilled-sessions.json
pending-reconciliation.txt
tools/ingest-state.json
tools/pending-ingest.txt
# transient ingest proposals awaiting human review
tools/staged/*
!tools/staged/.gitkeep

# generated metrics store (rebuild with make eval-db)
eval/results.db
